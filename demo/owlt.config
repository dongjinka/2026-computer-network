# owltsim configuration — injects a 600 s one-way light time on both directions
# of the Earth(1) <-> Mars(2) link. Run with:  owltsim owlt.config
#
# Line format (see `man owltsim`):
#   to  from  my_port#  dest_host  dest_port#  owlt(seconds)  modulus(0 = no loss)
#
# Earth -> Mars : owltsim listens on 9113 (node 1 udplso), holds 600 s, sends to node 2 udplsi (2113)
2 1 9113 127.0.0.1 2113 600 0
# Mars -> Earth : owltsim listens on 9112 (node 2 udplso), holds 600 s, sends to node 1 udplsi (1113)
1 2 9112 127.0.0.1 1113 600 0
